import numpy as np

house_data = np.array([
    [3, 1200, 6000000],
    [4, 2000, 12000000],
    [5, 2500, 15000000],
    [2, 900, 4000000],
    [4, 1800, 10000000]
])

bedrooms = house_data[:, 0]
sale_prices = house_data[:, 2]

average_price_more_than_four_bedrooms = np.mean(sale_prices[bedrooms > 4])

print(average_price_more_than_four_bedrooms)
